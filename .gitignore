# Secrets — never commit API keys
.env
.env.*

# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
venv/
my_env/

# Runtime artifacts (regenerated by the app)
logs/
chroma_db/

# Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
*.tsbuildinfo

# Synthea dataset — only the 7 tables the app reads are committed
sample_data/*
!sample_data/patients.csv
!sample_data/medications.csv
!sample_data/allergies.csv
!sample_data/conditions.csv
!sample_data/encounters.csv
!sample_data/observations.csv
!sample_data/procedures.csv
